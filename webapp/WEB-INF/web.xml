<web-app>
  <welcome-file-list><welcome-file>login.html</welcome-file></welcome-file-list>

  <servlet>
    <servlet-name>L</servlet-name>
    <servlet-class>com.example.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>L</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>D</servlet-name>
    <servlet-class>com.example.DashboardServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>D</servlet-name>
    <url-pattern>/dashboard</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>O</servlet-name>
    <servlet-class>com.example.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>O</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>
</web-app>
